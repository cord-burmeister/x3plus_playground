<?xml version="1.0"?>
<sdf version="1.10">
  <model name="Chair_Sky">
    <static>true</static>

    <link name="link">
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>meshes/visual.glb</uri>
          </mesh>
        </geometry>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh>
            <uri>meshes/collision.glb</uri>
          </mesh>
        </geometry>
      </collision>
    </link>
  </model>
</sdf>
