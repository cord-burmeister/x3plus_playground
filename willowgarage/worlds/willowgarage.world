<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="willow_garage_world">

    <!-- Ground plane -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Sun / lighting -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Willow Garage building -->
    <include>
      <uri>model://Willow_Garage</uri>
      <!-- Optional: pose if you want to shift it -->
      <!-- <pose>0 0 0 0 0 0</pose> -->
    </include>

  </world>
</sdf>
